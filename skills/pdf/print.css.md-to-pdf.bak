body {
  font-family: "PingFang TC", "Noto Sans CJK TC", "Microsoft JhengHei", "Heiti TC", sans-serif;
  font-size: 14px;
  line-height: 1.7;
  color: #1a1a1a;
}

h1, h2, h3, h4 {
  font-family: "PingFang TC", "Noto Sans CJK TC", sans-serif;
}

/* 表格不跨頁切斷 */
table {
  border-collapse: collapse;
  width: 100%;
  margin: 1em 0;
  page-break-inside: avoid;
}

/* 標題和表格不分離 */
h2, h3 {
  page-break-after: avoid;
}

tr {
  page-break-inside: avoid;
}

th, td {
  border: 1px solid #ccc;
  padding: 6px 10px;
  text-align: left;
  font-size: 13px;
}

th {
  background: #f5f5f5;
  font-weight: 600;
  white-space: nowrap;
}

blockquote {
  border-left: 4px solid #ddd;
  margin: 1em 0;
  padding: 0.5em 1em;
  color: #555;
  background: #fafafa;
}

code {
  background: #f0f0f0;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 0.9em;
}

hr {
  border: none;
  border-top: 1px solid #ddd;
  margin: 1.5em 0;
}
